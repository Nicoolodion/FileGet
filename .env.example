# Plex-Get configuration
# ---------------------------------------------------------------------------
# Mega-Debrid credentials
MEGADEBRID_LOGIN=your_login
MEGADEBRID_PASSWORD=your_password

# User/Group for file ownership inside the container (Unraid defaults: 99/100)
PUID=99
PGID=100

# Web UI port (host-side)
WEB_PORT=8000

# Concurrency: how many links to download in parallel
MAX_CONCURRENT_DOWNLOADS=2

# Database path inside the container (persisted via the ./data volume mount)
DATABASE_PATH=/app/data/plex-get.db

# Web / API basic auth (leave empty to disable)
WEB_USERNAME=
WEB_PASSWORD=

# DLC decryption service (JDownloader .dlc containers must be decrypted remotely).
# Defaults to the public https://dcrypt.it service. Self-host and override here
# if you prefer.
DCRYPT_BASE_URL=https://dcrypt.it

# ---------------------------------------------------------------------------
# HOST -> CONTAINER PATH MAPPING
#
# The application runs inside a container and only sees the *container* paths
# (`/media/Movies`, `/temp`, ...). The docker-compose.yml maps each HOST path
# listed below to its container counterpart. **You only need to edit the
# HOST_*_PATH variables.** The container paths are also wired into
# MEDIA_PATH_* and TEMP_PATH below; if you ever change a container path, update
# docker-compose.yml to match.
#
# Default placeholder values are intentionally generic; replace with paths
# that exist on your host system before starting the container.
# ---------------------------------------------------------------------------
HOST_MEDIA_PATH_MOVIES=/path/to/host/movies
HOST_MEDIA_PATH_SERIES=/path/to/host/series
HOST_MEDIA_PATH_ANIME_MOVIES=/path/to/host/anime-movies
HOST_MEDIA_PATH_ANIME_SERIES=/path/to/host/anime-series
HOST_MEDIA_PATH_UNCATEGORIZED=/path/to/host/uncategorized
HOST_TEMP_PATH=/path/to/host/temp

# Container-side paths (DO NOT CHANGE unless you also update docker-compose.yml)
MEDIA_PATH_MOVIES=/media/Movies
MEDIA_PATH_SERIES=/media/Series
MEDIA_PATH_ANIME_MOVIES=/media/Anime-Movies
MEDIA_PATH_ANIME_SERIES=/media/Anime-Series
MEDIA_PATH_UNCATEGORIZED=/media/Uncategorized
TEMP_PATH=/temp
